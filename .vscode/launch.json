{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Run: Guard Game",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**",
        "!**/.vite/**"
      ],
      "preLaunchTask": "vite: dev"
    }
  ]
}
